# Neon Postgres
# Use either DATABASE_URL or the NEON_* parts below.
DATABASE_URL=postgresql://user:password@ep-example.region.aws.neon.tech/neondb?sslmode=require
NEON_HOST=ep-example.region.aws.neon.tech
NEON_DATABASE=neondb
NEON_ROLE=neondb_owner
NEON_PASSWORD=your-neon-password
NEON_POOLER_HOST=ep-example-pooler.region.aws.neon.tech
NEXT_PUBLIC_APP_URL=https://unique-shuffle.netlify.app

## Optional: Analytics
# NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=your-posthog-host 
